{
  "title": "Firehose Abuse Scanner",
  "uid": "firehose-scanner",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [

    {
      "id": 1,
      "title": "Events received / sec",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 6 },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "rate(scanner_events_received_total[30s])",
        "legendFormat": "recv/s"
      }],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "purple" } } }
    },

    {
      "id": 2,
      "title": "Events processed / sec",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 0, "w": 8, "h": 6 },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "rate(scanner_events_processed_total[30s])",
        "legendFormat": "proc/s"
      }],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "green" } } }
    },

    {
      "id": 3,
      "title": "Events dropped / sec",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 6 },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "rate(scanner_events_dropped_total[30s])",
        "legendFormat": "drop/s"
      }],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "red" } } }
    },

    {
      "id": 4,
      "title": "Queue depth",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 6 },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "scanner_queue_depth",
        "legendFormat": "depth"
      }],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "orange" } } }
    },

    {
      "id": 5,
      "title": "Queue saturation",
      "type": "gauge",
      "gridPos": { "x": 12, "y": 6, "w": 6, "h": 6 },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "scanner_queue_saturation_ratio",
        "legendFormat": "saturation"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0, "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 0.6 },
              { "color": "red", "value": 0.8 }
            ]
          }
        }
      }
    },

    {
      "id": 6,
      "title": "P99 processing latency",
      "type": "timeseries",
      "gridPos": { "x": 18, "y": 6, "w": 6, "h": 6 },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "histogram_quantile(0.99, rate(scanner_event_processing_duration_seconds_bucket[1m]))",
        "legendFormat": "p99"
      }, {
        "datasource": "Prometheus",
        "expr": "histogram_quantile(0.50, rate(scanner_event_processing_duration_seconds_bucket[1m]))",
        "legendFormat": "p50"
      }],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },

    {
      "id": 7,
      "title": "ETL — spam keyword hits / sec",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 8, "h": 6 },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "rate(scanner_etl_spam_keyword_hits_total[30s])",
        "legendFormat": "{{keyword}}"
      }],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },

    {
      "id": 8,
      "title": "ETL — rate limit trips / sec",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 12, "w": 8, "h": 6 },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "rate(scanner_etl_rate_limit_trips_total[30s])",
        "legendFormat": "{{window}}"
      }],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },

    {
      "id": 9,
      "title": "ETL — flags written / sec (by reason)",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 12, "w": 8, "h": 6 },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "rate(scanner_etl_flagged_events_total[30s])",
        "legendFormat": "{{reason}}"
      }],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },

    {
      "id": 10,
      "title": "ETL — other signal hits / sec",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 18, "w": 12, "h": 6 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(scanner_etl_mention_storm_hits_total[30s])",
          "legendFormat": "mention storm"
        },
        {
          "datasource": "Prometheus",
          "expr": "rate(scanner_etl_repetition_hits_total[30s])",
          "legendFormat": "repetition"
        },
        {
          "datasource": "Prometheus",
          "expr": "rate(scanner_etl_excessive_caps_hits_total[30s])",
          "legendFormat": "excessive caps"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },

    {
      "id": 11,
      "title": "P99 flag write latency (Scylla)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 18, "w": 12, "h": 6 },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "histogram_quantile(0.99, rate(scanner_etl_flag_write_duration_seconds_bucket[1m]))",
        "legendFormat": "p99"
      }, {
        "datasource": "Prometheus",
        "expr": "histogram_quantile(0.50, rate(scanner_etl_flag_write_duration_seconds_bucket[1m]))",
        "legendFormat": "p50"
      }],
      "fieldConfig": { "defaults": { "unit": "s" } }
    }

  ]
}
