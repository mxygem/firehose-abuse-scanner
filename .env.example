# host:port the Prometheus container should scrape for scanner metrics.
# Default `host.docker.internal:9090` works on Docker Desktop (Mac/Windows)
# via the extra_hosts entry in docker-compose.yml. On WSL2 / native Linux
# where host.docker.internal does not resolve to the host, set this to the
# host's LAN IP (e.g. SCANNER_TARGET=192.168.1.42:9090).
SCANNER_TARGET=host.docker.internal:9090
